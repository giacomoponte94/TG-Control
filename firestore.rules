rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Documento principal de totais
    match /app/dados {
      allow read, write: if request.auth != null;
    }

    // Histórico de movimentações
    match /movimentacoes/{docId} {
      allow read, write: if request.auth != null;
    }

  }
}
